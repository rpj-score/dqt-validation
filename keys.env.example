# Copy this file to `.keys.env` in the project root and fill in your keys.
#   cp .keys.env.example .keys.env
#   $EDITOR .keys.env
#
# `.keys.env` is sourced by scripts/test_local_env.sh (via `set -a; source`).
# NEVER commit a populated .keys.env — it is in .gitignore.

# === LLM provider keys ==================================================
# The script pins every Hinaing agent node to a single provider set by the
# LLM_PROVIDER env (default: groq). Populate at least that provider's key.
#
# Groq (fastest, default):            https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (multi-model via one key): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Google Gemini:                      https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === Eval judge =========================================================
# Anthropic — enables the independent Claude judge for groundedness and
# adversarial scoring (`hinaing-eval score --llm-judge`). Without this the
# eval falls back to heuristic keyword checks.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Optional: web search + fact-check ==================================
# Leave blank to disable those paths during local eval.
# Tavily:            https://app.tavily.com/
# LangSearch:        https://langsearch.com/
# Google Fact Check: enable "Fact Check Tools API" in the Google Cloud
#                    project that hosts your Gemini key.
TAVILY_API_KEY=
LANGSEARCH_API_KEY=
GOOGLE_FACT_CHECK_API_KEY=

# === Optional: observability (NOT required) =============================
# LangSmith is not read by any Hinaing code path. Populate only if you want
# LangChain tracing enabled.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pr-local-eval

# === Optional: ingestion keys (unused by fixture-mode eval) =============
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
APIFY_API_TOKEN=
